# Root `.env` applies to catalog-server and Vite. Vite also merges frontend/.env*
# for local SPA-only overrides. Only VITE_* vars are exposed to the browser.
#
PORT=8080
CATALOG_DATA_DIR=data
APP_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
APP_ENV=development

# Secure default: JWT-scoped customer access. For an explicit public demo, set
# APP_ENV=demo, DEMO_MODE=true, and VITE_DEMO_MODE=true. DEMO_MODE alone does
# not enable the browser SPA demo path.
DEMO_MODE=false
VITE_DEMO_MODE=false

AUTH_ISSUER=https://issuer.example
AUTH_AUDIENCE=catalog-api
AUTH_JWKS_URL=https://issuer.example/.well-known/jwks.json
AUTH_CUSTOMER_CLAIM=customer_id
AUTH_ALLOWED_ALGS=RS256

# Frontend OIDC settings
VITE_OIDC_AUTHORITY=https://issuer.example
VITE_OIDC_CLIENT_ID=catalog-match-spa
VITE_OIDC_REDIRECT_URI=http://127.0.0.1:5173/auth/callback
VITE_OIDC_SCOPE=openid profile
VITE_OIDC_AUDIENCE=catalog-api
